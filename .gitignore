# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Rust build output (src-tauri has its own .gitignore too, but this
# covers the top level in case cargo is ever run from here)
/src-tauri/target/

# Claude Code local-only state (machine-specific permissions/session
# locks, not meant to be shared)
.claude/settings.local.json
.claude/scheduled_tasks.lock
src-tauri/.claude/settings.local.json

# Dev-time symlinks to locally-served dashboard assets (point at
# ephemeral scratch paths, not real content)
/data/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
